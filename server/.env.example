# 复制为 .env 后修改
DATABASE_URL="mysql://seafishing:seafishing@127.0.0.1:3306/seafishing?connection_limit=10&pool_timeout=20"

# 微信小程序（生产环境必填）
WX_APPID=""
WX_SECRET=""

# 开发模式：未配置 WX_SECRET 时，code 以 dev: 开头可本地联调
WX_DEV_MODE=true

JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="7d"

ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

PORT=3000
