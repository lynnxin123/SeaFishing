<view class="login-page">
  <view class="login-bg-wrap">
    <view class="login-bg-img-wrap">
      <image class="login-bg" src="{{bgImage}}" mode="widthFix" lazy-load="{{true}}" show-menu-by-longpress="{{false}}"></image>
      <view class="login-bg-edge-fade"></view>
    </view>
    <view class="login-bg-fill"></view>
  </view>
  <view class="login-overlay"></view>

  <view class="login-back" bindtap="onBack">
    <view class="login-back-icon"></view>
  </view>

  <view class="login-body">
    <view class="brand-block">
      <view class="brand-name-wrap">
        <view class="brand-name-line"></view>
        <view class="brand-name">海发海钓</view>
        <view class="brand-name-line"></view>
      </view>
    </view>

    <view class="login-footer">
      <view class="btn-action-wrap" wx:if="{{agreed}}">
        <button
          class="btn-action btn-outline"
          open-type="getPhoneNumber"
          bindtap="onLoginTap"
          bindgetphonenumber="onGetPhoneNumber"
        >登录</button>
      </view>
      <view class="btn-action-wrap" wx:if="{{notAgreed}}">
        <view class="btn-action btn-outline" bindtap="onLoginTap">登录</view>
      </view>
      <view class="btn-action btn-gold" bindtap="onSkipLogin">暂不登录</view>

      <view class="agreement-row">
        <view class="agree-check {{agreed ? 'agree-check-on' : ''}}" bindtap="onToggleAgree">
          <view class="agree-tick" wx:if="{{agreed}}"></view>
        </view>
        <view class="agreement-text-wrap">
          <view class="agreement-line">
            <text class="agreement-plain">查看并同意</text>
            <view class="agreement-link" catchtap="onOpenAgreement" data-type="user">{{userAgreementLabel}}</view>
            <text class="agreement-plain">，</text>
            <view class="agreement-link" catchtap="onOpenAgreement" data-type="privacy">{{privacyPolicyLabel}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
