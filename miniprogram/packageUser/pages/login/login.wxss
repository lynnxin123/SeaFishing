page {
  height: 100%;
  background: #0a1e3d;
  overflow: hidden;
}

.login-page {
  position: relative;
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #0a1e3d;
  box-sizing: border-box;
}

.login-bg-wrap {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: #0a2d4f;
}

.login-bg-img-wrap {
  position: relative;
  width: 100%;
  flex-shrink: 0;
}

/* widthFix 等比缩放、顶部对齐，不拉伸 */
.login-bg {
  width: 100%;
  height: auto;
  display: block;
  vertical-align: top;
}

/* 图片底缘渐隐，与下方海色填充衔接 */
.login-bg-edge-fade {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 180rpx;
  background: linear-gradient(
    180deg,
    rgba(10, 45, 79, 0) 0%,
    rgba(10, 42, 74, 0.45) 50%,
    #0a2d4f 100%
  );
  pointer-events: none;
}

/* 图片下方用海面深蓝填充，与图片底部融为一体 */
.login-bg-fill {
  flex: 1;
  min-height: 0;
  background: linear-gradient(
    180deg,
    #0a2d4f 0%,
    #0a2545 40%,
    #0a1e3d 100%
  );
}

.login-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(8, 24, 48, 0) 0%,
    rgba(8, 24, 48, 0) 55%,
    rgba(8, 24, 48, 0.38) 100%
  );
  pointer-events: none;
}

.login-back {
  position: relative;
  z-index: 10;
  flex-shrink: 0;
  padding: calc(env(safe-area-inset-top) + 16rpx) 0 8rpx 32rpx;
}

.login-back-icon {
  width: 22rpx;
  height: 22rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

.login-body {
  position: relative;
  z-index: 2;
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding-top: 0;
}

.brand-block {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  padding: 200rpx 48rpx 72rpx;
  box-sizing: border-box;
}

.brand-name-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  width: 100%;
}

.brand-name-line {
  flex: 1;
  max-width: 120rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(245, 227, 176, 0.85), transparent);
}

.brand-name {
  flex-shrink: 0;
  font-size: 60rpx;
  font-weight: 700;
  letter-spacing: 10rpx;
  color: #f8e8c4;
  line-height: 1.2;
  text-shadow:
    0 1rpx 0 rgba(255, 255, 255, 0.5),
    0 3rpx 12rpx rgba(0, 0, 0, 0.35),
    0 0 32rpx rgba(212, 175, 55, 0.4);
}

/* 底部按钮区 */
.login-footer {
  flex-shrink: 0;
  padding: 0 56rpx calc(32rpx + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.btn-action-wrap {
  width: 100%;
}

.btn-action-wrap .btn-outline {
  width: 100%;
}

.btn-action {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 34rpx;
  box-sizing: border-box;
  display: block;
}

.btn-outline {
  font-weight: 600;
  color: #f0dfa0;
  background: rgba(10, 30, 60, 0.22);
  border: 2rpx solid rgba(212, 184, 114, 0.9);
  border-radius: 999rpx;
  padding: 0;
  margin: 0;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.15);
}

button.btn-outline {
  width: 100% !important;
  min-width: 0;
}

.btn-outline::after {
  border: none;
}

.btn-gold {
  font-weight: 600;
  letter-spacing: 4rpx;
  color: #1a2d4f;
  border-radius: 999rpx;
  border: 1rpx solid rgba(255, 240, 200, 0.7);
  background: linear-gradient(
    90deg,
    #9a7b2f 0%,
    #c4a030 20%,
    #f2e2a8 46%,
    #e0c878 68%,
    #c9a227 86%,
    #a67c1a 100%
  );
  box-shadow:
    0 8rpx 22rpx rgba(0, 0, 0, 0.22),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.5),
    inset 0 -1rpx 2rpx rgba(140, 100, 20, 0.2);
}

.btn-gold:active {
  opacity: 0.92;
  box-shadow:
    0 4rpx 14rpx rgba(0, 0, 0, 0.18),
    inset 0 2rpx 4rpx rgba(255, 255, 255, 0.4);
}

.agreement-row {
  display: flex;
  align-items: flex-start;
  justify-content: center;
  gap: 12rpx;
  margin-top: 8rpx;
  padding: 0 4rpx;
  width: 100%;
}

.agree-check {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 50%;
  flex-shrink: 0;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.agree-check-on {
  background: #0c6dff;
  border-color: #0c6dff;
}

.agree-tick {
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(-45deg);
  margin-top: -4rpx;
}

.agreement-text-wrap {
  flex: none;
  min-width: 0;
}

.agreement-line {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  font-size: 24rpx;
  line-height: 36rpx;
}

.agreement-link {
  display: inline;
  color: #ffffff;
  margin: 0 4rpx;
}

.agreement-plain {
  color: rgba(255, 255, 255, 0.92);
}

.dev-accounts {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: rgba(0, 0, 0, 0.35);
}

.dev-accounts__title {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-bottom: 16rpx;
  text-align: center;
}

.dev-accounts__row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
}

.dev-accounts__btn {
  padding: 10rpx 20rpx;
  font-size: 22rpx;
  color: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  border-radius: 999rpx;
  background: rgba(12, 109, 255, 0.35);
}
