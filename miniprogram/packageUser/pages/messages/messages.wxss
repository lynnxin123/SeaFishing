.messages-page {
  min-height: 100vh;
  background: #f5f7f9;
}

.messages-body {
  min-height: calc(100vh - 120rpx);
}

.messages-scroll {
  height: calc(100vh - 120rpx);
}

.messages-loading,
.messages-empty {
  padding: 24rpx;
}

.message-skeleton {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.message-skeleton__title {
  width: 50%;
  height: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.message-skeleton__line {
  width: 90%;
  height: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 12rpx;
}

.message-skeleton__time {
  width: 35%;
  height: 20rpx;
  border-radius: 10rpx;
}

.message-card {
  margin: 0 24rpx 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.04);
}

.message-card--unread {
  border-left: 6rpx solid #0c6dff;
}

.message-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.message-card__title {
  font-size: 30rpx;
  font-weight: 600;
  color: #141d3a;
}

.message-card__dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff4d4f;
}

.message-card__content {
  display: block;
  font-size: 26rpx;
  color: #5e7b9a;
  line-height: 38rpx;
}

.message-card__time {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #98a4b8;
}

.messages-empty {
  padding-top: 200rpx;
  text-align: center;
}

.messages-empty__icon {
  display: block;
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.messages-empty__text {
  color: #5e7b9a;
  font-size: 28rpx;
}

.messages-retry {
  display: inline-block;
  margin-top: 28rpx;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: #0b4f8c;
  color: #ffffff;
  font-size: 26rpx;
}

.skeleton-shimmer {
  background: linear-gradient(90deg, #f0f2f5 25%, #e4e8ee 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  animation: messages-skeleton-shimmer 1.4s ease infinite;
}

@keyframes messages-skeleton-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
