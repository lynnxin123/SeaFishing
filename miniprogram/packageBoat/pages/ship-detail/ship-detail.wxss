.detail-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.detail-error {
  padding: 200rpx 48rpx 48rpx;
  text-align: center;
}

.detail-error__icon {
  display: block;
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

.detail-error__text {
  display: block;
  color: #2b3a55;
  font-size: 30rpx;
  font-weight: 600;
}

.detail-error__retry {
  display: inline-block;
  margin-top: 28rpx;
  padding: 18rpx 48rpx;
  border-radius: 999rpx;
  background: #0b4f8c;
  color: #ffffff;
  font-size: 26rpx;
}

.detail-content {
  width: 100%;
}

/* 顶部船舶块 */
.ship-head {
  background: #ffffff;
  padding-bottom: 28rpx;
}

.ship-name {
  padding: 24rpx 24rpx 0;
  font-size: 36rpx;
  font-weight: 700;
  color: #141d3a;
  line-height: 48rpx;
  margin-bottom: 20rpx;
}

.ship-cover {
  width: 100%;
  height: 360rpx;
  border-radius: 0;
  display: block;
  background: #eef2f6;
}

.ship-brief {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 20rpx 24rpx 0;
  gap: 16rpx;
}

.ship-spec {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 38rpx;
}

.ship-fee {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #666666;
  white-space: nowrap;
}

.fee-label,
.fee-suffix {
  color: #666666;
}

.fee-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #141d3a;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #f0f1f3;
  border-bottom: 1rpx solid #e8e8e8;
}

.tab-item {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 26rpx 8rpx 22rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 40rpx;
}

.tab-item-active .tab-text {
  font-weight: 700;
  color: #141d3a;
}

.tab-indicator {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  background: #141d3a;
  border-radius: 3rpx;
}

/* Tab 内容区 */
.tab-panel {
  background: #ffffff;
}

.section-card {
  padding: 28rpx 24rpx;
}

.section-card-simple {
  padding-bottom: 24rpx;
}

.section-card-last {
  padding-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #141d3a;
  margin-bottom: 20rpx;
}

.section-divider {
  height: 1rpx;
  background: #eeeeee;
  margin: 0 24rpx;
}

.info-line {
  font-size: 26rpx;
  color: #666666;
  line-height: 42rpx;
}

.info-line.muted {
  color: #999999;
}

.info-grid {
  display: flex;
  gap: 24rpx;
}

.info-col {
  flex: 1;
  min-width: 0;
}

.facility-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.facility-tag {
  padding: 10rpx 24rpx;
  border: 1rpx solid #d8dce3;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #141d3a;
  background: #f7f8fa;
  line-height: 36rpx;
}

/* 船长信息 */
.captain-block {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.captain-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #eef2f6;
}

.captain-main {
  flex: 1;
  min-width: 0;
}

.captain-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.captain-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #141d3a;
}

.captain-tag {
  padding: 4rpx 14rpx;
  border: 1rpx solid #9ec5ff;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #0c6dff;
  background: #eef6ff;
  line-height: 30rpx;
}

.captain-stats {
  font-size: 26rpx;
  color: #666666;
  line-height: 38rpx;
}

.stat-gap {
  margin-left: 24rpx;
}

.stat-highlight {
  color: #f68c1e;
  font-weight: 600;
}

.plain-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 44rpx;
}

.review-add-btn {
  margin-top: 24rpx;
  text-align: center;
  padding: 18rpx;
  border-radius: 999rpx;
  background: #eef6ff;
  color: #0c6dff;
  font-size: 26rpx;
  font-weight: 600;
}

.empty-tip {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  padding: 40rpx 0;
}

.review-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-user {
  display: block;
  font-size: 26rpx;
  color: #141d3a;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.review-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 40rpx;
}

.scroll-bottom-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.bottom-left {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.bottom-action-text {
  font-size: 22rpx;
  color: #666666;
}

.icon-symbol {
  font-size: 44rpx;
  color: #666666;
  line-height: 44rpx;
  height: 44rpx;
}

.icon-symbol-active {
  color: #ff5a5a;
}

.icon-share-wrap {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #666666;
  border-radius: 8rpx;
  position: relative;
  box-sizing: border-box;
  margin-top: 4rpx;
}

.icon-share-arrow {
  position: absolute;
  left: 50%;
  top: -14rpx;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 12rpx solid #666666;
}

.book-btn {
  flex: 1;
  max-width: 420rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #141d3a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-left: 24rpx;
}

.booking-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.4);
}

.booking-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  display: flex;
  flex-direction: column;
  max-height: 90vh;
  background: #ffffff;
  border-radius: 34rpx 34rpx 0 0;
  overflow: hidden;
  box-shadow: 0 -16rpx 48rpx rgba(0, 0, 0, 0.16);
}

.booking-header {
  flex-shrink: 0;
  padding: 36rpx 32rpx 28rpx;
  background: linear-gradient(135deg, #eef7ff 0%, #ffffff 100%);
}

.booking-title {
  display: block;
  font-size: 36rpx;
  color: #0b4f8c;
  font-weight: 700;
  line-height: 1.3;
}

.booking-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7b92b1;
  line-height: 1.4;
}

.booking-scroll {
  height: calc(90vh - 320rpx - env(safe-area-inset-bottom));
  min-height: 360rpx;
  max-height: 1100rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.booking-summary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  margin: 8rpx 0 20rpx;
  border-radius: 20rpx;
  background: #f7fbff;
  border: 1rpx solid #d7e8fc;
}

.booking-summary-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

.booking-summary-main {
  flex: 1;
  min-width: 0;
}

.booking-summary-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #0b4f8c;
  line-height: 1.35;
}

.booking-summary-meta {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #536d8b;
}

.booking-summary-price {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0c6dff;
}

.booking-field {
  margin-bottom: 20rpx;
}

.booking-section-title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #0b4f8c;
}

.booking-info-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.booking-info-item {
  flex: 1;
  min-width: calc(50% - 8rpx);
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  background: #f7fbff;
  border: 1rpx solid #d7e8fc;
  box-sizing: border-box;
}

.booking-info-label {
  display: block;
  font-size: 22rpx;
  color: #7b92b1;
  margin-bottom: 6rpx;
}

.booking-info-value {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #0b4f8c;
  line-height: 1.4;
}

.booking-info-input {
  width: 100%;
  height: 44rpx;
  line-height: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #0b4f8c;
  background: transparent;
}

.booking-divider {
  height: 1rpx;
  margin: 8rpx 0 24rpx;
  background: #e8f0fa;
}

.booking-label-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.booking-label {
  font-size: 24rpx;
  color: #536d8b;
  font-weight: 500;
}

.booking-tag {
  font-size: 18rpx;
  line-height: 1.4;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

.booking-tag--req {
  background: #fff0f0;
  color: #e54545;
}

.booking-tag--opt {
  background: #eef1f5;
  color: #8a96a8;
}

.booking-tag--test {
  background: #fff8e8;
  color: #c98a00;
}

.booking-input {
  width: 100%;
  box-sizing: border-box;
  height: 80rpx;
  line-height: 80rpx;
  padding: 0 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d7e8fc;
  background: #ffffff;
  font-size: 28rpx;
  color: #2b3a55;
}

.booking-actions {
  flex-shrink: 0;
  display: flex;
  gap: 20rpx;
  padding: 20rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #e8f0fa;
}

.booking-cancel,
.booking-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.booking-cancel {
  background: #eef7ff;
  color: #0c6dff;
  border: 1rpx solid #d7e8fc;
}

.booking-confirm {
  background: linear-gradient(135deg, #0c6dff 0%, #0b4f8c 100%);
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(12, 109, 255, 0.28);
}

.booking-type-row {
  display: flex;
  gap: 16rpx;
}

.booking-type {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 16rpx;
  background: #f7fbff;
  border: 1rpx solid #d7e8fc;
  color: #536d8b;
  font-size: 28rpx;
}

.booking-type--active {
  background: linear-gradient(135deg, #0c6dff 0%, #0b4f8c 100%);
  border-color: transparent;
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(12, 109, 255, 0.22);
}

.slot-hint {
  font-size: 24rpx;
  color: #7b92b1;
  padding: 12rpx 0;
}

.slot-hint--retry {
  color: #0c6dff;
}

.slot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.slot-item {
  min-width: calc(50% - 8rpx);
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid #d7e8fc;
  background: #f7fbff;
  box-sizing: border-box;
}

.slot-item--active {
  border-color: #0c6dff;
  background: #eef7ff;
  box-shadow: 0 6rpx 16rpx rgba(12, 109, 255, 0.15);
}

.slot-item--disabled {
  opacity: 0.5;
  background: #f5f7fa;
}

.slot-time {
  display: block;
  font-size: 28rpx;
  color: #0b4f8c;
  font-weight: 600;
}

.slot-stock {
  display: block;
  font-size: 22rpx;
  color: #7b92b1;
  margin-top: 6rpx;
}

.booking-rules {
  margin-bottom: 24rpx;
  padding: 20rpx;
  background: #f7fbff;
  border: 1rpx solid #d7e8fc;
  border-radius: 16rpx;
}

.booking-rules-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #0b4f8c;
  margin-bottom: 10rpx;
}

.booking-rules-line {
  display: block;
  font-size: 22rpx;
  color: #536d8b;
  line-height: 36rpx;
}
