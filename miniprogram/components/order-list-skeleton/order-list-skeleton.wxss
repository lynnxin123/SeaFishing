.order-skeleton-list {
  padding: 24rpx;
}

.order-skeleton-card {
  display: flex;
  flex-direction: row;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.order-skeleton-cover {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #e8e8e8;
}

.order-skeleton-main {
  flex: 1;
  padding: 20rpx 20rpx 20rpx 0;
  margin-left: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.order-skeleton-line {
  height: 24rpx;
  border-radius: 12rpx;
}

.order-skeleton-line--title {
  width: 72%;
  height: 30rpx;
}

.order-skeleton-line--short {
  width: 48%;
}

.skeleton-shimmer {
  background: linear-gradient(90deg, #f0f2f5 25%, #e4e8ee 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  animation: order-skeleton-shimmer 1.4s ease infinite;
}

@keyframes order-skeleton-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
