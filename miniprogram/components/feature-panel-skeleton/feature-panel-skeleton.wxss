.feature-skeleton-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(11, 79, 140, 0.06);
}

.feature-skeleton-title {
  width: 40%;
  height: 30rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.feature-skeleton-rank,
.feature-skeleton-stat {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 18rpx;
}

.feature-skeleton-no {
  width: 56rpx;
  height: 28rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.feature-skeleton-name {
  flex: 1;
  height: 28rpx;
  border-radius: 12rpx;
}

.feature-skeleton-score {
  width: 88rpx;
  height: 28rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.feature-skeleton-label {
  flex: 1;
  height: 28rpx;
  border-radius: 12rpx;
  max-width: 200rpx;
}

.feature-skeleton-value {
  width: 100rpx;
  height: 28rpx;
  border-radius: 12rpx;
  margin-left: auto;
}

.skeleton-shimmer {
  background: linear-gradient(90deg, #f0f2f5 25%, #e4e8ee 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  animation: feature-skeleton-shimmer 1.4s ease infinite;
}

@keyframes feature-skeleton-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
