.index-skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.index-skeleton-card {
  border-radius: 30rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 18rpx 38rpx rgba(9, 57, 120, 0.12);
}

.index-skeleton-image {
  width: 100%;
  height: 280rpx;
}

.index-skeleton-body {
  padding: 24rpx 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.index-skeleton-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.index-skeleton-line {
  height: 24rpx;
  border-radius: 12rpx;
}

.index-skeleton-line--title {
  flex: 1;
  height: 30rpx;
  max-width: 55%;
}

.index-skeleton-line--short {
  width: 42%;
}

.index-skeleton-price {
  width: 140rpx;
  height: 28rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.index-skeleton-foot {
  margin-top: 6rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.index-skeleton-tag {
  width: 120rpx;
  height: 40rpx;
  border-radius: 22rpx;
}

.index-skeleton-btn {
  width: 160rpx;
  height: 52rpx;
  border-radius: 26rpx;
}

.skeleton-shimmer {
  background: linear-gradient(90deg, #f0f2f5 25%, #e4e8ee 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  animation: index-skeleton-shimmer 1.4s ease infinite;
}

@keyframes index-skeleton-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
