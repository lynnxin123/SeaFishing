<view class="skeleton-list">
  <view wx:for="{{count}}" wx:key="*this" class="skeleton-card">
    <view class="skeleton-row">
      <view class="skeleton-image skeleton-shimmer"></view>
      <view class="skeleton-content">
        <view class="skeleton-line skeleton-line--title skeleton-shimmer"></view>
        <view class="skeleton-line skeleton-line--sub skeleton-shimmer"></view>
        <view class="skeleton-line skeleton-line--meta skeleton-shimmer"></view>
        <view class="skeleton-line skeleton-line--short skeleton-shimmer"></view>
      </view>
    </view>
    <view class="skeleton-divider"></view>
    <view class="skeleton-footer">
      <view class="skeleton-avatar skeleton-shimmer"></view>
      <view class="skeleton-line skeleton-line--captain skeleton-shimmer"></view>
      <view class="skeleton-price skeleton-shimmer"></view>
    </view>
  </view>
</view>
