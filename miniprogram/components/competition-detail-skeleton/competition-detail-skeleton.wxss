.comp-detail-skeleton__hero {
  width: 100%;
  height: 420rpx;
}

.comp-detail-skeleton__body {
  padding: 28rpx 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comp-detail-skeleton__line {
  height: 26rpx;
  border-radius: 12rpx;
}

.comp-detail-skeleton__line--en {
  width: 40%;
  height: 22rpx;
}

.comp-detail-skeleton__line--title {
  width: 72%;
  height: 36rpx;
}

.comp-detail-skeleton__line--short {
  width: 55%;
}

.comp-detail-skeleton__btn {
  margin-top: 12rpx;
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
}

.skeleton-shimmer {
  background: linear-gradient(90deg, #f0f2f5 25%, #e4e8ee 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  animation: comp-detail-skeleton-shimmer 1.4s ease infinite;
}

@keyframes comp-detail-skeleton-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
