.comp-skeleton-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.comp-skeleton-card {
  background: #ffffff;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid #eef2f7;
  box-shadow: 0 14rpx 36rpx rgba(11, 79, 140, 0.1);
}

.comp-skeleton-banner {
  width: 100%;
  height: 400rpx;
}

.comp-skeleton-body {
  padding: 24rpx 28rpx 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.comp-skeleton-line {
  height: 24rpx;
  border-radius: 12rpx;
}

.comp-skeleton-line--en {
  width: 36%;
  height: 20rpx;
}

.comp-skeleton-line--title {
  width: 78%;
  height: 32rpx;
}

.comp-skeleton-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 4rpx;
}

.comp-skeleton-line--meta {
  width: 64%;
}

.comp-skeleton-btn {
  margin-top: 8rpx;
  width: 100%;
  height: 72rpx;
  border-radius: 36rpx;
}

.skeleton-shimmer {
  background: linear-gradient(90deg, #f0f2f5 25%, #e4e8ee 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  animation: comp-skeleton-shimmer 1.4s ease infinite;
}

@keyframes comp-skeleton-shimmer {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
