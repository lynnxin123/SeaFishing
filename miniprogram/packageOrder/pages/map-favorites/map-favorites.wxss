@import "../booking-orders/booking-orders.wxss";

.skeleton-wrap {
  min-height: 400rpx;
}

.empty-icon {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.empty-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.empty-btn {
  margin-top: 32rpx;
  padding: 16rpx 48rpx;
  background: #0b4f8c;
  color: #ffffff;
  font-size: 28rpx;
  border-radius: 999rpx;
}

.spot-card {
  display: flex;
  flex-direction: row;
  align-items: center;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.spot-card-main {
  flex: 1;
  min-width: 0;
}

.spot-type {
  font-size: 22rpx;
  color: #0c6dff;
  background: #e8f2ff;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.menu-arrow {
  font-size: 40rpx;
  color: #cccccc;
  margin-left: 12rpx;
}
