<view class="orders-page">
  <navigation-bar title="收藏的船只" back="{{true}}" color="#141414" background="#ffffff"></navigation-bar>

  <view class="orders-body">
    <view wx:if="{{loading}}" class="skeleton-wrap">
      <ship-list-skeleton count="{{3}}" />
    </view>

    <view wx:elif="{{loadError}}" class="empty-wrap">
      <text class="empty-icon" aria-hidden="true">⚠</text>
      <text class="empty-text">{{loadError}}</text>
      <text class="empty-hint">请检查网络后重试</text>
      <view class="empty-btn" bindtap="loadList">重新加载</view>
    </view>

    <view wx:elif="{{isEmpty}}" class="empty-wrap">
      <text class="empty-text">暂无收藏船只</text>
      <text class="empty-hint">在船舶详情页点击收藏后，会显示在这里</text>
      <view class="empty-btn" bindtap="onGoBoat">去约船看看</view>
    </view>

    <scroll-view wx:else class="order-scroll" scroll-y enhanced show-scrollbar="{{false}}">
      <view class="order-list">
        <view
          wx:for="{{list}}"
          wx:key="boatId"
          class="boat-card"
          data-index="{{index}}"
          bindtap="onItemTap"
        >
          <image lazy-load class="boat-cover" src="{{item.coverImage}}" mode="aspectFill" />
          <view class="boat-main">
            <view class="order-title-row">
              <text class="order-ship">{{item.shipName}}</text>
              <text class="boat-score">{{item.scoreDisplay}}分</text>
            </view>
            <text class="order-meta">船长：{{item.captain}}</text>
            <text class="order-meta">码头：{{item.wharf}}</text>
            <view class="boat-foot">
              <text class="boat-price">¥{{item.price}}起</text>
              <text class="menu-arrow">›</text>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</view>
