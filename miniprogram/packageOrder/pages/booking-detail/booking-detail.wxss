@import '../booking-orders/booking-orders.wxss';

.detail-page {
  min-height: 100vh;
  background: #f0f2f5;
  box-sizing: border-box;
}

.detail-scroll {
  width: 100%;
  height: calc(100vh - env(safe-area-inset-top) - 88px - 160rpx - env(safe-area-inset-bottom));
  min-height: 400rpx;
  box-sizing: border-box;
}

.card--last {
  margin-bottom: 24rpx;
}

.cover {
  width: 100%;
  height: 360rpx;
}

.card {
  margin: 20rpx 24rpx 0;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.ship-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #141414;
}

.status {
  font-size: 24rpx;
  color: #0c6dff;
}

.meta {
  display: block;
  font-size: 26rpx;
  color: #666;
  line-height: 40rpx;
}

.meta.price {
  color: #e67e22;
  font-weight: 600;
  margin-top: 8rpx;
}

.meta.pay-tip {
  color: #0c6dff;
  margin-top: 8rpx;
}

.meta.warn {
  color: #d93025;
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.rule-line {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 38rpx;
}

.cancel-status {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.cancel-status.ok {
  color: #0c6dff;
}

.cancel-status.no {
  color: #999;
}

.foot {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #eee;
}

.foot-actions {
  display: flex;
  gap: 16rpx;
}

.foot-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.foot-btn.primary {
  color: #fff;
  background: #0c6dff;
}

.foot-btn.danger {
  color: #fff;
  background: #d93025;
}

.foot-btn.disabled {
  color: #999;
  background: #eee;
}

.loading-wrap,
.empty-wrap {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #666;
}

.retry-btn {
  margin-top: 24rpx;
  color: #0c6dff;
}
