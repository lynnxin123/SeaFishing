.orders-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f0f2f5;
}

.tab-scroll {
  flex-shrink: 0;
  width: 100%;
  background: #f5f7f9;
  border-bottom: 1rpx solid #e8e8e8;
}

.tab-row {
  display: inline-flex;
  flex-direction: row;
  align-items: flex-end;
  padding: 0 8rpx;
  white-space: nowrap;
}

.tab-item {
  position: relative;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 28rpx 20rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 40rpx;
}

.tab-item--active .tab-text {
  font-weight: 600;
  color: #141414;
}

.tab-line {
  margin-top: 8rpx;
  width: 48rpx;
  height: 6rpx;
  background: #141414;
  border-radius: 3rpx;
}

.orders-body {
  flex: 1;
  min-height: 0;
}

.order-scroll {
  height: calc(100vh - 200rpx);
}

.order-list {
  padding: 24rpx;
}

.order-card {
  display: flex;
  flex-direction: row;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.order-cover {
  width: 200rpx;
  height: 200rpx;
  flex-shrink: 0;
  background: #e8e8e8;
}

.order-main {
  flex: 1;
  min-width: 0;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.order-title-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.order-ship {
  font-size: 30rpx;
  font-weight: 600;
  color: #141414;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-status {
  font-size: 24rpx;
  color: #0c6dff;
  flex-shrink: 0;
}

.order-meta {
  font-size: 24rpx;
  color: #888888;
  line-height: 36rpx;
}

.order-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.order-btn {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #333333;
  background: #f5f7f9;
  border: 1rpx solid #e8e8e8;
}

.order-btn--danger {
  color: #d4380d;
  background: #fff2e8;
  border-color: #ffbb96;
}

.order-btn--primary {
  color: #0c6dff;
  background: #eef6ff;
  border-color: #91caff;
}

.skeleton-wrap {
  min-height: 400rpx;
}

.empty-hint {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #bbbbbb;
}

.empty-icon {
  font-size: 56rpx;
  line-height: 1;
  margin-bottom: 16rpx;
}

.retry-btn {
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: #141414;
  color: #ffffff;
  font-size: 26rpx;
}

.order-foot {
  margin-top: auto;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding-top: 8rpx;
}

.order-no {
  font-size: 22rpx;
  color: #aaaaaa;
}

.order-price {
  font-size: 28rpx;
  font-weight: 600;
  color: #e53935;
}

.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 280rpx;
}

.empty-icon {
  position: relative;
  width: 160rpx;
  height: 180rpx;
  margin-bottom: 32rpx;
}

.empty-doc {
  position: absolute;
  left: 20rpx;
  top: 0;
  width: 120rpx;
  height: 150rpx;
  border: 4rpx solid #c8c8c8;
  border-radius: 8rpx;
  box-sizing: border-box;
}

.empty-line {
  position: absolute;
  left: 44rpx;
  height: 4rpx;
  background: #c8c8c8;
  border-radius: 2rpx;
}

.empty-line--1 {
  top: 48rpx;
  width: 72rpx;
}

.empty-line--2 {
  top: 72rpx;
  width: 56rpx;
}

.empty-line--3 {
  top: 96rpx;
  width: 64rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999999;
}
