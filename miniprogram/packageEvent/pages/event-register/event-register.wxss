.register-page {
  min-height: 100vh;
  background: #f5f9fc;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.register-error {
  padding: 200rpx 48rpx 48rpx;
  text-align: center;
}

.register-error__icon {
  display: block;
  font-size: 56rpx;
  margin-bottom: 20rpx;
}

.register-error__text {
  display: block;
  color: #2b3a55;
  font-size: 30rpx;
  font-weight: 600;
}

.register-error__retry {
  display: inline-block;
  margin-top: 28rpx;
  padding: 18rpx 48rpx;
  border-radius: 999rpx;
  background: #0b4f8c;
  color: #ffffff;
  font-size: 26rpx;
}

.register-head {
  margin: 16rpx 24rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(11, 79, 140, 0.06);
}

.register-head__label {
  display: block;
  font-size: 24rpx;
  color: #98a4b8;
}

.register-head__name {
  display: block;
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #141d3a;
}

.register-head__meta {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #5e7b9a;
  line-height: 36rpx;
}

.register-form {
  margin: 20rpx 24rpx 0;
  padding: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 28rpx rgba(11, 79, 140, 0.06);
}

.form-item {
  margin-bottom: 28rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 26rpx;
  color: #2b3a55;
  margin-bottom: 14rpx;
  font-weight: 600;
}

.required {
  color: #e53935;
  margin-right: 4rpx;
}

.form-input,
.form-textarea {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #dcdfe6;
  border-radius: 16rpx;
  padding: 0 22rpx;
  background: #f8fafc;
  color: #2b3a55;
  font-size: 28rpx;
}

.form-input {
  height: 80rpx;
  line-height: 80rpx;
}

.form-textarea {
  min-height: 160rpx;
  padding: 20rpx 22rpx;
  line-height: 40rpx;
}

.register-foot {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eef2f7;
}

.register-submit {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: linear-gradient(135deg, #0c6dff, #0b4f8c);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}
