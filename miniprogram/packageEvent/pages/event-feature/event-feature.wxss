.feature-page {
  min-height: 100vh;
  background: #f5f9fc;
}

.feature-body {
  padding: 24rpx;
}

.feature-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(11, 79, 140, 0.06);
}

.feature-card__title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #141d3a;
}

.feature-card__subtitle {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #141d3a;
  margin-bottom: 20rpx;
}

.feature-card__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #5f6f86;
}

.feature-card--error {
  text-align: center;
}

.feature-card__desc--error {
  color: #2b3a55;
  font-weight: 600;
}

.feature-retry {
  display: inline-block;
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: #0b4f8c;
  color: #ffffff;
  font-size: 26rpx;
}

.stat-row,
.rank-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #eef2f6;
}

.stat-label,
.rank-name {
  font-size: 26rpx;
  color: #5f6f86;
}

.stat-value,
.rank-score {
  font-size: 26rpx;
  color: #141d3a;
  font-weight: 600;
}

.rank-no {
  width: 64rpx;
  font-size: 26rpx;
  color: #0c6dff;
  font-weight: 700;
}

.feature-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  background: #f7fafc;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.feature-submit {
  margin-top: 24rpx;
  text-align: center;
  padding: 22rpx;
  border-radius: 999rpx;
  background: #0c6dff;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 600;
}

.feature-input {
  width: 100%;
  box-sizing: border-box;
  margin-top: 16rpx;
  padding: 20rpx;
  background: #f7fafc;
  border-radius: 16rpx;
  font-size: 26rpx;
}

.feature-tip {
  text-align: center;
  font-size: 22rpx;
  color: #98a4b8;
  padding: 16rpx 24rpx 40rpx;
}
