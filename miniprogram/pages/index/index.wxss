.page-scroll {
  width: 100%;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #0b4f8c 0%, #1a70cf 42%, #eaf6ff 100%);
}

.hero-area {
  padding: 28rpx 24rpx 24rpx;
  background: transparent;
}

.hero-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.hero-left {
  display: flex;
  flex-direction: column;
}

.hero-location {
  display: flex;
  align-items: center;
  color: #ffffff;
  font-size: 24rpx;
}

.hero-location-text {
  font-weight: 700;
}

.hero-location-sub {
  margin-left: 10rpx;
  font-size: 22rpx;
}

.hero-tag {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.88);
  font-size: 22rpx;
}

.hero-icons {
  display: flex;
  gap: 12rpx;
}

.icon-box {
  width: 62rpx;
  height: 62rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.18);
  color: #ffffff;
  font-size: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-title-wrap {
  margin-top: 32rpx;
}

.hero-label {
  font-size: 24rpx;
  color: #74d6ff;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 44rpx;
  color: #ffffff;
  font-weight: 800;
  line-height: 58rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
}

.hero-swiper {
  margin-top: 24rpx;
  width: 100%;
  height: 360rpx;
  border-radius: 32rpx;
  overflow: hidden;
  background: #ffffff;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.info-block {
  padding: 0 24rpx;
  margin-top: -80rpx;
}

.weather-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 24rpx;
  box-shadow: 0 24rpx 46rpx rgba(9, 55, 111, 0.12);
}

.weather-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.weather-date {
  color: #0c6dff;
  font-size: 26rpx;
  font-weight: 700;
}

.weather-temp {
  display: block;
  font-size: 46rpx;
  color: #0b4f8c;
  font-weight: 800;
  margin: 12rpx 0;
}

.weather-detail {
  font-size: 24rpx;
  color: #536d8b;
}

.weather-tide {
  width: 44%;
  background: #eef7ff;
  border-radius: 28rpx;
  padding: 20rpx 16rpx;
}

.tide-row {
  margin-bottom: 16rpx;
}

.tide-label {
  font-size: 24rpx;
  color: #0c6dff;
}

.tide-time {
  display: block;
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #0b4f8c;
  font-weight: 700;
}

.tide-height {
  font-size: 22rpx;
  color: #5f7d9f;
  margin-top: 6rpx;
}

.weather-footer {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  color: #7b92b1;
  font-size: 22rpx;
}

.tabs-block {
  margin: 22rpx 24rpx 4rpx;
  background: #f7fbff;
  border-radius: 38rpx;
  padding: 20rpx;
  box-shadow: 0 20rpx 44rpx rgba(12, 87, 171, 0.08);
}

.tabs-header {
  display: flex;
  background: #eef7ff;
  border-radius: 32rpx;
  padding: 10rpx;
}

.tabs-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 28rpx;
  color: #4a7db4;
  font-size: 26rpx;
}

.tabs-item.active {
  background: #0c6dff;
  color: #ffffff;
  box-shadow: 0 8rpx 20rpx rgba(12, 109, 255, 0.18);
}

.tabs-content {
  margin-top: 24rpx;
}

.form-box {
  margin-bottom: 20rpx;
  background: #ffffff;
  border-radius: 30rpx;
  padding: 20rpx;
}

.form-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #d7e8fc;
}

.form-row:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 26rpx;
  color: #0f5a94;
}

.form-picker {
  min-width: 220rpx;
}

.form-value {
  display: inline-block;
  padding: 12rpx 18rpx;
  border-radius: 26rpx;
  background: #f6fbff;
  color: #0d5db5;
  font-size: 24rpx;
}

.pax-box {
  display: flex;
  align-items: center;
  border-radius: 32rpx;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid #d7e8fc;
}

.pax-btn {
  width: 84rpx;
  height: 84rpx;
  line-height: 84rpx;
  text-align: center;
  color: #0c6dff;
  background: #eef7ff;
  font-size: 34rpx;
}

.pax-number {
  width: 92rpx;
  text-align: center;
  color: #0b4f8c;
  font-size: 26rpx;
}

.index-load-wrap {
  margin-bottom: 8rpx;
}

.index-error-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #fff8f0;
  border: 1rpx solid #ffe2c2;
}

.index-error-card,
.index-empty-card {
  margin-bottom: 20rpx;
  padding: 40rpx 28rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 38rpx rgba(9, 57, 120, 0.12);
  text-align: center;
}

.index-error-text,
.index-empty-text {
  color: #5e7d9a;
  font-size: 26rpx;
  line-height: 40rpx;
}

.index-retry-btn {
  display: inline-block;
  margin-top: 24rpx;
  padding: 16rpx 40rpx;
  border-radius: 999rpx;
  background: #0c6dff;
  color: #ffffff;
  font-size: 26rpx;
}

.index-retry-btn--inline {
  margin-top: 0;
  flex-shrink: 0;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
}

.boat-card,
.event-card {
  margin-bottom: 20rpx;
  border-radius: 30rpx;
  overflow: hidden;
  background: #ffffff;
  box-shadow: 0 18rpx 38rpx rgba(9, 57, 120, 0.12);
}

.boat-image,
.event-image {
  width: 100%;
  height: 280rpx;
}

.boat-content,
.event-content {
  padding: 24rpx 22rpx 24rpx;
}

.boat-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.boat-name,
.event-name {
  font-size: 30rpx;
  color: #0a4f8c;
  font-weight: 700;
}

.boat-price {
  font-size: 26rpx;
  color: #0b6dff;
  font-weight: 700;
}

.boat-info {
  font-size: 24rpx;
  color: #5e7d9a;
  line-height: 34rpx;
}

.boat-foot {
  margin-top: 18rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.boat-tag {
  padding: 8rpx 18rpx;
  border-radius: 22rpx;
  background: #eef6ff;
  color: #0b6dff;
  font-size: 22rpx;
}

.reserve-btn {
  padding: 14rpx 30rpx;
  border-radius: 26rpx;
  background: #0c6dff;
  color: #ffffff;
  font-size: 24rpx;
}

.event-meta {
  display: flex;
  justify-content: space-between;
  color: #6d8aa8;
  font-size: 24rpx;
  margin-top: 14rpx;
}

