.map-page {
  min-height: 100vh;
  background: #ffffff;
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.hero-wrap {
  position: relative;
  width: 100%;
  overflow: hidden;
  padding: 28rpx 24rpx 160rpx;
  background: #ffffff;
  box-sizing: border-box;
}

/* 背景图不铺满底部留白区，避免裁切硬边 */
.hero-wrap__bg {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: calc(100% - 160rpx);
  display: block;
}

.hero-wrap__mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.06) 0%,
    rgba(0, 0, 0, 0) 10%,
    rgba(255, 255, 255, 0) 18%,
    rgba(255, 255, 255, 0.08) 28%,
    rgba(255, 255, 255, 0.2) 38%,
    rgba(255, 255, 255, 0.38) 48%,
    rgba(255, 255, 255, 0.56) 58%,
    rgba(255, 255, 255, 0.72) 68%,
    rgba(255, 255, 255, 0.86) 78%,
    rgba(255, 255, 255, 0.95) 88%,
    #ffffff 96%,
    #ffffff 100%
  );
  pointer-events: none;
}

.hero-wrap__fade {
  position: absolute;
  left: 0;
  right: 0;
  top: 22%;
  bottom: 0;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.18) 28%,
    rgba(255, 255, 255, 0.48) 52%,
    rgba(255, 255, 255, 0.78) 72%,
    rgba(255, 255, 255, 0.95) 88%,
    #ffffff 100%
  );
  pointer-events: none;
}

.hero-wrap__bottom {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 200rpx;
  z-index: 1;
  background: #ffffff;
  pointer-events: none;
}

.hero-tagline {
  position: relative;
  z-index: 2;
  padding: 8rpx 8rpx 28rpx;
  pointer-events: none;
}

.hero-tagline__main {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 6rpx;
  line-height: 1.4;
  text-shadow: 0 4rpx 16rpx rgba(0, 30, 80, 0.35);
}

.hero-tagline__sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 30, 80, 0.25);
}

.map-body {
  position: relative;
  z-index: 3;
  margin-top: -148rpx;
  padding-top: 0;
  background: #ffffff;
}

.weather-card {
  position: relative;
  z-index: 2;
  margin: 0 0 12rpx;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid rgba(232, 238, 245, 0.9);
  border-radius: 28rpx;
  box-shadow:
    0 16rpx 40rpx rgba(11, 79, 140, 0.12),
    0 2rpx 8rpx rgba(11, 79, 140, 0.06);
  backdrop-filter: blur(12px);
}

.weather-card__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.weather-card__title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.weather-card__accent {
  width: 6rpx;
  height: 28rpx;
  border-radius: 6rpx;
  background: linear-gradient(180deg, #0c6dff, #0b4f8c);
}

.weather-card__title {
  font-size: 30rpx;
  font-weight: 700;
  color: #141d3a;
  letter-spacing: 2rpx;
}

.weather-card__date {
  font-size: 22rpx;
  color: #98a4b8;
}

.weather-main {
  display: flex;
  gap: 24rpx;
}

.weather-left {
  flex: 1;
  min-width: 0;
}

.weather-hero {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weather-icon {
  font-size: 52rpx;
  line-height: 1;
}

.weather-hero__info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.weather-temp {
  font-size: 44rpx;
  font-weight: 700;
  color: #141d3a;
  line-height: 1.1;
}

.weather-desc {
  font-size: 24rpx;
  color: #5e7b9a;
}

.weather-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.meta-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  background: #f4f8fc;
  border-radius: 14rpx;
  border: 1rpx solid #e8eef5;
}

.meta-chip__label {
  font-size: 22rpx;
  color: #98a4b8;
}

.meta-chip__value {
  font-size: 22rpx;
  color: #2b3a55;
  font-weight: 600;
}

.meta-chip__value--warn {
  color: #e53935;
}

.wind-alert {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  background: linear-gradient(90deg, #fff5f5, #fffafa);
  border: 1rpx solid #ffd4d4;
  border-radius: 16rpx;
}

.wind-alert__icon {
  font-size: 24rpx;
  color: #e53935;
  line-height: 1.4;
  flex-shrink: 0;
}

.wind-alert__text {
  font-size: 22rpx;
  color: #d32f2f;
  line-height: 1.5;
}

.weather-tide {
  flex-shrink: 0;
  width: 168rpx;
  padding: 16rpx;
  background: linear-gradient(180deg, #f0f7ff 0%, #f8fbff 100%);
  border-radius: 20rpx;
  border: 1rpx solid #dce9f8;
}

.tide-head {
  font-size: 22rpx;
  font-weight: 700;
  color: #0b4f8c;
  margin-bottom: 14rpx;
  letter-spacing: 2rpx;
}

.tide-item {
  margin-bottom: 16rpx;
}

.tide-item:last-child {
  margin-bottom: 0;
}

.tide-item__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.tide-label {
  font-size: 22rpx;
  color: #5e7b9a;
  font-weight: 500;
}

.tide-time {
  font-size: 22rpx;
  color: #2b3a55;
  font-weight: 600;
}

.tide-height {
  display: block;
  margin-top: 4rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #0b4f8c;
  line-height: 1.2;
}

.filter-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin: 0 24rpx;
  padding-top: 0;
}

.filter-toggle {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 20rpx;
  background: #ffffff;
  border: 1rpx solid #e8eef5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #2b3a55;
  box-shadow: 0 4rpx 14rpx rgba(11, 79, 140, 0.06);
}

.filter-icon {
  width: 26rpx;
  height: 26rpx;
}

.filter-arrow {
  color: #98a4b8;
  margin-left: 4rpx;
}

.filter-tags {
  flex: 1;
  min-width: 0;
}

.tag-row {
  display: inline-flex;
  gap: 12rpx;
  white-space: nowrap;
}

.filter-tag {
  padding: 14rpx 22rpx;
  background: #ffffff;
  border: 1rpx solid #e8eef5;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #5e7b9a;
  box-shadow: 0 4rpx 12rpx rgba(11, 79, 140, 0.04);
  transition: all 0.2s ease;
}

.filter-tag.active {
  background: linear-gradient(135deg, #0c6dff, #0b4f8c);
  color: #ffffff;
  font-weight: 600;
  border-color: transparent;
  box-shadow: 0 6rpx 18rpx rgba(11, 79, 140, 0.22);
}

.filter-panel {
  margin: 12rpx 24rpx 0;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.06);
}

.panel-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #141d3a;
  margin-bottom: 16rpx;
}

.panel-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  padding: 12rpx 24rpx;
  border: 1rpx solid #dcdfe6;
  border-radius: 18rpx;
  font-size: 24rpx;
  color: #2b3a55;
  background: #f8fafc;
}

.chip-active {
  background: #0c6dff;
  border-color: #0c6dff;
  color: #ffffff;
}

.panel-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.panel-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.panel-btn-ghost {
  background: #f0f4f8;
  color: #5e7b9a;
}

.panel-btn-primary {
  background: #0b4f8c;
  color: #ffffff;
  font-weight: 600;
}

.map-wrap {
  position: relative;
  margin: 16rpx 24rpx 0;
  height: 520rpx;
  border-radius: 28rpx;
  overflow: hidden;
  border: 1rpx solid #e8eef5;
  box-shadow: 0 14rpx 36rpx rgba(11, 79, 140, 0.12);
}

.fishing-map {
  width: 100%;
  height: 100%;
}

.map-legend {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  background-color: rgba(255, 255, 255, 0.92);
  border-radius: 14rpx;
  padding: 12rpx 16rpx;
}

.legend-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  margin-bottom: 8rpx;
}

.legend-item:last-child {
  margin-bottom: 0;
}

.legend-text {
  font-size: 20rpx;
  color: #2b3a55;
  margin-left: 8rpx;
  line-height: 20rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
}

.dot-shore { background-color: #22a05a; }
.dot-pier { background-color: #0c6dff; }
.dot-deep { background-color: #f58c18; }
.dot-event { background-color: #e63946; }

.map-mode-bar {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.94);
  border-radius: 16rpx;
  padding: 4rpx;
}

.map-mode-item {
  padding: 10rpx 22rpx;
  font-size: 22rpx;
  line-height: 28rpx;
  color: #5a6b85;
  border-radius: 12rpx;
}

.map-mode-on {
  background-color: #0b4f8c;
  color: #ffffff;
  font-weight: 600;
}

.locate-btn {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 14rpx 20rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  font-size: 24rpx;
  color: #0b4f8c;
  line-height: 28rpx;
}

.locate-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  line-height: 28rpx;
}

.spot-list-card {
  margin: 16rpx 24rpx 24rpx;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 24rpx;
  border: 1rpx solid #eef2f7;
  box-shadow: 0 10rpx 28rpx rgba(11, 79, 140, 0.06);
}

.list-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #141d3a;
  margin-bottom: 16rpx;
}

.spot-list {
  width: 100%;
}

.spot-list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
}

.spot-list-item:last-child {
  border-bottom: none;
}

.spot-list-item-disabled {
  opacity: 0.5;
}

.spot-list-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.spot-list-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #141d3a;
  flex: 1;
}

.spot-list-dist {
  font-size: 24rpx;
  color: #0c6dff;
  font-weight: 600;
}

.spot-list-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #98a4b8;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.spot-type-tag {
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  font-size: 20rpx;
}

.type-shore { background: #e8f8ef; color: #22a05a; }
.type-pier { background: #e8f2ff; color: #0c6dff; }
.type-deep { background: #fff4e8; color: #f58c18; }

.event-tag {
  color: #e53935;
  font-weight: 600;
}

.list-empty {
  text-align: center;
  padding: 40rpx 0;
  color: #98a4b8;
  font-size: 26rpx;
}

.spot-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 200;
}

.spot-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  background: #ffffff;
  border-radius: 28rpx 28rpx 0 0;
  padding: 28rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  max-height: 78vh;
  overflow-y: auto;
}

.spot-panel-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.spot-panel-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #141d3a;
}

.spot-event-badge {
  display: inline-block;
  margin-top: 8rpx;
  padding: 4rpx 14rpx;
  background: #ffe8ea;
  color: #e53935;
  font-size: 22rpx;
  border-radius: 8rpx;
}

.spot-panel-actions {
  display: flex;
  gap: 16rpx;
}

.icon-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  background: #f0f4f8;
  color: #5e7b9a;
  font-size: 30rpx;
}

.icon-btn-active {
  color: #ffb400;
  background: #fff8e6;
}

.spot-info-row {
  display: flex;
  padding: 10rpx 0;
  font-size: 26rpx;
  color: #2b3a55;
  line-height: 38rpx;
}

.spot-info-row .label {
  width: 150rpx;
  flex-shrink: 0;
  color: #98a4b8;
}

.wind-block-tip {
  margin: 16rpx 0;
  padding: 16rpx 20rpx;
  background: #fff3f3;
  color: #e53935;
  border-radius: 14rpx;
  font-size: 24rpx;
}

.event-link-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 16rpx 0;
  padding: 20rpx 24rpx;
  background: linear-gradient(90deg, #ffe8ea, #fff5f5);
  border-radius: 16rpx;
  border: 1rpx solid #ffc9cf;
}

.event-link-text {
  font-size: 26rpx;
  color: #e53935;
  font-weight: 600;
}

.event-link-arrow {
  font-size: 36rpx;
  color: #e53935;
}

.spot-ships {
  margin-top: 12rpx;
}

.ships-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #141d3a;
  margin-bottom: 16rpx;
}

.ship-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f2f7;
}

.ship-row-disabled {
  opacity: 0.45;
  pointer-events: none;
}

.ship-thumb {
  width: 96rpx;
  height: 72rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #eef2f6;
}

.ship-main {
  flex: 1;
  min-width: 0;
}

.ship-name {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #141d3a;
}

.ship-meta {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #98a4b8;
}

.ship-price {
  font-size: 30rpx;
  font-weight: 700;
  color: #0b4f8c;
}

.price-suffix {
  font-size: 22rpx;
  color: #98a4b8;
  font-weight: 400;
}

.spot-foot {
  margin-top: 20rpx;
}

.nav-btn {
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #0b4f8c;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
}
