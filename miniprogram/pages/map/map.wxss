.page-shell { min-height: 100vh; padding: 30rpx 24rpx 160rpx; background: #e6f5ff; }
.page-title { font-size: 36rpx; font-weight: 700; color: #0b4f8c; margin-bottom: 24rpx; }
.placeholder-card { background: #ffffff; border-radius: 28rpx; padding: 28rpx; box-shadow: 0 14rpx 32rpx rgba(0,0,0,0.10); }
.placeholder-title { font-size: 28rpx; color: #0c6dff; margin-bottom: 14rpx; }
.placeholder-text { color: #5e7b9a; font-size: 24rpx; line-height: 36rpx; }
