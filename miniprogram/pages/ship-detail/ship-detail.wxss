.detail-page {
  min-height: 100vh;
  background: #f5f6f8;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.detail-content {
  width: 100%;
}

/* 顶部船舶块 */
.ship-head {
  background: #ffffff;
  padding-bottom: 28rpx;
}

.ship-name {
  padding: 24rpx 24rpx 0;
  font-size: 36rpx;
  font-weight: 700;
  color: #141d3a;
  line-height: 48rpx;
  margin-bottom: 20rpx;
}

.ship-cover {
  width: 100%;
  height: 360rpx;
  border-radius: 0;
  display: block;
  background: #eef2f6;
}

.ship-brief {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 20rpx 24rpx 0;
  gap: 16rpx;
}

.ship-spec {
  flex: 1;
  font-size: 26rpx;
  color: #666666;
  line-height: 38rpx;
}

.ship-fee {
  flex-shrink: 0;
  font-size: 26rpx;
  color: #666666;
  white-space: nowrap;
}

.fee-label,
.fee-suffix {
  color: #666666;
}

.fee-price {
  font-size: 32rpx;
  font-weight: 700;
  color: #141d3a;
}

/* Tab 栏 */
.tab-bar {
  display: flex;
  background: #f0f1f3;
  border-bottom: 1rpx solid #e8e8e8;
}

.tab-item {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 26rpx 8rpx 22rpx;
}

.tab-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 40rpx;
}

.tab-item-active .tab-text {
  font-weight: 700;
  color: #141d3a;
}

.tab-indicator {
  position: absolute;
  left: 50%;
  bottom: 0;
  transform: translateX(-50%);
  width: 56rpx;
  height: 6rpx;
  background: #141d3a;
  border-radius: 3rpx;
}

/* Tab 内容区 */
.tab-panel {
  background: #ffffff;
}

.section-card {
  padding: 28rpx 24rpx;
}

.section-card-simple {
  padding-bottom: 24rpx;
}

.section-card-last {
  padding-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #141d3a;
  margin-bottom: 20rpx;
}

.section-divider {
  height: 1rpx;
  background: #eeeeee;
  margin: 0 24rpx;
}

.info-line {
  font-size: 26rpx;
  color: #666666;
  line-height: 42rpx;
}

.info-line.muted {
  color: #999999;
}

.info-grid {
  display: flex;
  gap: 24rpx;
}

.info-col {
  flex: 1;
  min-width: 0;
}

.facility-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.facility-tag {
  padding: 10rpx 24rpx;
  border: 1rpx solid #d8dce3;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #141d3a;
  background: #f7f8fa;
  line-height: 36rpx;
}

/* 船长信息 */
.captain-block {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.captain-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #eef2f6;
}

.captain-main {
  flex: 1;
  min-width: 0;
}

.captain-name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.captain-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #141d3a;
}

.captain-tag {
  padding: 4rpx 14rpx;
  border: 1rpx solid #9ec5ff;
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #0c6dff;
  background: #eef6ff;
  line-height: 30rpx;
}

.captain-stats {
  font-size: 26rpx;
  color: #666666;
  line-height: 38rpx;
}

.stat-gap {
  margin-left: 24rpx;
}

.stat-highlight {
  color: #f68c1e;
  font-weight: 600;
}

.plain-text {
  font-size: 28rpx;
  color: #666666;
  line-height: 44rpx;
}

.empty-tip {
  font-size: 28rpx;
  color: #999999;
  text-align: center;
  padding: 40rpx 0;
}

.review-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.review-user {
  display: block;
  font-size: 26rpx;
  color: #141d3a;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.review-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 40rpx;
}

.scroll-bottom-spacer {
  height: calc(120rpx + env(safe-area-inset-bottom));
}

/* 底部固定栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eeeeee;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.bottom-left {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.bottom-action-text {
  font-size: 22rpx;
  color: #666666;
}

.icon-symbol {
  font-size: 44rpx;
  color: #666666;
  line-height: 44rpx;
  height: 44rpx;
}

.icon-symbol-active {
  color: #ff5a5a;
}

.icon-share-wrap {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid #666666;
  border-radius: 8rpx;
  position: relative;
  box-sizing: border-box;
  margin-top: 4rpx;
}

.icon-share-arrow {
  position: absolute;
  left: 50%;
  top: -14rpx;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 10rpx solid transparent;
  border-right: 10rpx solid transparent;
  border-bottom: 12rpx solid #666666;
}

.book-btn {
  flex: 1;
  max-width: 420rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #141d3a;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 12rpx;
  margin-left: 24rpx;
}

.booking-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.45);
}

.booking-sheet {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 201;
  background: #ffffff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx calc(32rpx + env(safe-area-inset-bottom));
}

.booking-sheet-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #141d3a;
  text-align: center;
  margin-bottom: 32rpx;
}

.booking-field {
  margin-bottom: 28rpx;
}

.booking-label {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.booking-picker,
.booking-input {
  width: 100%;
  box-sizing: border-box;
  min-height: 80rpx;
  line-height: 80rpx;
  border: 1rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 0 24rpx;
  background: #f8f8f8;
  color: #333333;
  font-size: 28rpx;
}

.booking-input {
  height: 80rpx;
}

.booking-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
}

.booking-cancel,
.booking-confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.booking-cancel {
  background: #f0f1f3;
  color: #666666;
}

.booking-confirm {
  background: #141d3a;
  color: #ffffff;
}
