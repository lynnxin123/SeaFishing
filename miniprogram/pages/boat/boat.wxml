<wxs module="util" src="./boat.wxs"></wxs>
<view class="page-shell">
  <navigation-bar title="海钓约船" back="{{false}}" color="black" background="#ffffff"></navigation-bar>

  <!-- 背景图铺满至卡片底边，卡片悬浮叠在背景之上 -->
  <view class="hero-wrap">
    <image lazy-load class="hero-wrap__bg" src="{{heroBanner}}" mode="aspectFill" />
    <view class="hero-wrap__mask"></view>
    <view class="hero-wrap__fade"></view>
    <view class="hero-wrap__bottom"></view>
    <view class="hero-banner__title-wrap">
      <text class="hero-banner__title">海钓起航 渔乐无穷</text>
    </view>
    <view class="search-card">
    <view class="form-row">
      <view class="form-item">
        <text class="form-label">请选择预约日期</text>
        <picker class="form-picker" mode="date" value="{{search.date}}" bindchange="onDateChange" start="2000-01-01" end="2099-12-31">
          <view class="picker-value">{{search.date}}</view>
        </picker>
      </view>
      <view class="form-item">
        <text class="form-label">请选择出港码头</text>
        <picker class="form-picker" mode="selector" range="{{wharfOptions}}" value="{{search.wharfIndex}}" bindchange="onWharfChange">
          <view class="picker-value">{{search.wharf}}</view>
        </picker>
      </view>
    </view>
    <view class="form-row">
      <view class="form-item">
        <text class="form-label">乘船人数</text>
        <input class="text-input" type="number" placeholder="请输入乘船人数" value="{{search.people}}" bindinput="onPeopleInput" bindblur="onPeopleBlur" />
      </view>
      <view class="form-item">
        <text class="form-label">船号/船长</text>
        <input class="text-input" type="text" placeholder="请输入船号/船长" value="{{search.keyword}}" bindinput="onKeywordInput" bindblur="onKeywordBlur" />
      </view>
    </view>
    <button class="search-button" bindtap="onSearch">搜索</button>
    </view>
  </view>

  <view class="page-body">
  <view wx:if="{{!hasSearched && !loadingShips && !listError}}" class="search-hint-card">
    <text class="search-hint-text">填写预约条件后，点击「搜索」查看可用渔船</text>
  </view>

  <!-- 搜索结果区 -->
  <view wx:if="{{loadingShips && !hasSearched}}" class="list-container">
    <ship-list-skeleton count="{{4}}" />
  </view>

  <view wx:elif="{{listError === '加载失败，请重试' && !loadingShips}}" class="error-card">
    <text class="error-icon" aria-hidden="true">⚠</text>
    <text class="error-text">{{listError}}</text>
    <text class="error-hint">请检查网络后重试</text>
    <view class="retry-btn" bindtap="onRetryLoad">重新加载</view>
  </view>

  <block wx:elif="{{hasSearched}}">
  <view class="result-header">
    <view class="result-left">搜索结果</view>
    <view class="result-actions">
      <view class="action-button" bindtap="toggleSortPopup">
        <image class="action-icon" src="/images/icon-sort-price.png" mode="aspectFit" />
        <text>{{currentSortText}}</text>
        <text class="action-arrow">∨</text>
      </view>
      <view class="action-button" bindtap="toggleFilterPopup">
        <image class="action-icon" src="/images/icon-filter.png" mode="aspectFit" />
        <text>筛选</text>
      </view>
    </view>
  </view>

  <view class="list-container">
    <view wx:if="{{listTotal === 0 && listError === '暂无船只'}}" class="empty-card">
      <text class="empty-text">暂无可用船只，请稍后再试或调整搜索条件。</text>
    </view>
    <view wx:elif="{{listTotal === 0 && hasSearched}}" class="empty-card">
      <text class="empty-text">暂无符合条件的出海渔船，请调整筛选条件重新搜索。</text>
    </view>
    <block wx:for="{{visibleShips}}" wx:for-item="item" wx:key="boatId">
      <view class="ship-card" bindtap="onShipTap" data-index="{{index}}">
        <view class="ship-row">
          <view class="ship-image-wrap">
            <image lazy-load src="{{item.images[0] || '/images/boat1.jpg'}}" class="ship-image" mode="aspectFill" />
          </view>
          <view class="ship-content">
            <view class="ship-header">
              <view class="ship-title">{{item.shipName}}</view>
            </view>
            <view class="ship-submeta">
              <text>可载客{{item.maxNum}}人</text>
              <text class="dot">·</text>
              <text>{{item.shipLen ? '长' + item.shipLen + '米' : '长暂无'}}</text>
              <text class="dot">·</text>
              <text>{{item.shipWid ? '宽' + item.shipWid + '米' : '宽暂无'}}</text>
            </view>
            <view class="ship-stats-row">
              <view class="stat">评分：<text class="stat-value">{{item.scoreDisplay}}</text></view>
              <view class="stat">近三个月出航：<text class="stat-value">{{item.sailCount}}次</text></view>
            </view>
            <view class="ship-wharf-row">
              <text>码头：{{item.displayWharf}} 船号：{{item.boatId}}</text>
            </view>
          </view>
        </view>
        <view class="ship-divider-dashed"></view>
        <view class="captain-row-full">
          <block wx:if="{{item.captainAvatar}}">
            <image lazy-load class="captain-avatar-img" src="{{item.captainAvatar}}" mode="aspectFill" />
          </block>
          <block wx:else>
            <view class="captain-avatar">{{item.captain.substr(0,1)}}</view>
          </block>
          <view class="captain-info">
            <text class="captain-name" title="{{item.captain}}">船长：{{item.captain}}</text>
          </view>
          <view class="ship-price">¥{{item.price}}<text class="price-suffix">起</text></view>
        </view>
      </view>
    </block>
    <view wx:if="{{loadingMore}}" class="list-footer">
      <text class="list-footer-text">加载更多...</text>
    </view>
  </view>
  </block>
  </view>

  <!-- 综合排序弹窗（置于 page-shell 顶层，避免被搜索卡片遮挡） -->
  <view wx:if="{{showSortPopup}}" class="popup-mask" catchtouchmove="stopPopupTap">
    <view class="popup-mask-bg" bindtap="toggleSortPopup"></view>
    <view class="popup-sheet" catchtap="stopPopupTap" catchtouchmove="stopPopupTap">
      <view class="popup-title-row">
        <text class="popup-title">综合排序</text>
        <view class="popup-close" catchtap="toggleSortPopup">×</view>
      </view>
      <block wx:for="{{sortOptions}}" wx:key="value">
        <view class="popup-option {{currentSort === item.value ? 'popup-option-active' : ''}}" bindtap="onSortSelect" data-value="{{item.value}}">
          {{item.label}}
        </view>
      </block>
    </view>
  </view>

  <!-- 全筛选弹窗 -->
  <view wx:if="{{showFilterPopup}}" class="popup-mask" catchtouchmove="stopPopupTap">
    <view class="popup-mask-bg" bindtap="onFilterCancel"></view>
    <view class="popup-sheet filter-sheet" catchtap="stopPopupTap" catchtouchmove="stopPopupTap">
      <view class="popup-title-row">
        <text class="popup-title">筛选</text>
        <view class="popup-close" catchtap="onFilterCancel">×</view>
      </view>
      <view class="filter-section">
        <text class="filter-label">船舶设施</text>
        <view class="filter-options wrap">
          <view class="filter-chip {{filtersDraft.facilities.length === 0 ? 'active' : ''}}" catchtap="onFilterFacilityToggle" data-value="all">全部</view>
          <view wx:for="{{facilityOptions}}" wx:key="value" class="filter-chip {{util.includes(filtersDraft.facilities, item.value) ? 'active' : ''}}" catchtap="onFilterFacilityToggle" data-value="{{item.value}}">{{item.label}}</view>
        </view>
      </view>
      <view class="filter-section">
        <text class="filter-label">船舶长度</text>
        <view class="filter-options">
          <view wx:for="{{lengthOptions}}" wx:key="value" class="filter-chip {{filtersDraft.length === item.value ? 'active' : ''}}" catchtap="onFilterLengthSelect" data-value="{{item.value}}">{{item.label}}</view>
        </view>
      </view>
      <view class="filter-section">
        <text class="filter-label">船长经验</text>
        <view class="filter-options wrap">
          <view wx:for="{{experienceOptions}}" wx:key="value" class="filter-chip {{filtersDraft.experience === item.value ? 'active' : ''}}" catchtap="onFilterExperienceSelect" data-value="{{item.value}}">{{item.label}}</view>
        </view>
      </view>
      <view class="filter-section">
        <text class="filter-label">船长评分</text>
        <view class="filter-options wrap">
          <view wx:for="{{scoreOptions}}" wx:key="value" class="filter-chip {{filtersDraft.score === item.value ? 'active' : ''}}" catchtap="onFilterScoreSelect" data-value="{{item.value}}">{{item.label}}</view>
        </view>
      </view>
      <view class="filter-footer">
        <view class="reset-btn" catchtap="onFilterReset">重置</view>
        <view class="confirm-btn" catchtap="onFilterConfirm">确定</view>
      </view>
    </view>
  </view>
</view>
