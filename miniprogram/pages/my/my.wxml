<view class="my-page">
  <view class="nav-bar">
    <text class="nav-title">我的</text>
  </view>

  <view class="top-panel">
    <view wx:if="{{!isLoggedIn}}" class="user-header">
      <view class="login-hit" bindtap="onGoLogin">
        <view class="login-hit-inner">
          <image class="avatar avatar-guest-img" src="/images/my-icon-avatar.png" mode="aspectFit"></image>
          <view class="login-tip">请点击登录</view>
        </view>
      </view>
      <view class="bell-btn" catchtap="onBellTap">
        <view class="ui-bell" aria-hidden="true">
          <view class="ui-bell__handle"></view>
          <view class="ui-bell__dome"></view>
          <view class="ui-bell__rim"></view>
          <view class="ui-bell__clapper"></view>
        </view>
      </view>
    </view>

    <!-- 已登录 -->
    <view wx:else class="user-header">
      <image
        wx:if="{{userInfo.avatarUrl}}"
        class="avatar"
        src="{{userInfo.avatarUrl}}"
        mode="aspectFill"
      ></image>
      <image wx:else class="avatar avatar-guest-img" src="/images/my-icon-avatar.png" mode="aspectFit"></image>
      <view class="user-meta">
        <view class="name-row">
          <text class="user-name">{{userInfo.nickName}}</text>
          <text class="tag-verify" wx:if="{{showUnverified}}" bindtap="onGoVerify">未实名</text>
        </view>
        <view class="level-tag">
          <text class="level-crown">♛</text>
          <text class="level-text">{{userInfo.levelName}}</text>
        </view>
      </view>
      <view class="bell-btn" bindtap="onBellTap">
        <view class="ui-bell" aria-hidden="true">
          <view class="ui-bell__handle"></view>
          <view class="ui-bell__dome"></view>
          <view class="ui-bell__rim"></view>
          <view class="ui-bell__clapper"></view>
        </view>
      </view>
    </view>

    <view class="checkin-row" wx:if="{{isLoggedIn}}">
      <view class="checkin-btn" bindtap="onCheckIn">每日签到 +5积分</view>
      <view class="reward-link" bindtap="onToggleRewards">{{showRewards ? '收起' : '积分明细'}}</view>
    </view>

    <view class="reward-panel" wx:if="{{isLoggedIn && showRewards}}">
      <view wx:if="{{rewardLogs.length === 0}}" class="reward-empty">暂无积分记录</view>
      <view class="reward-item" wx:for="{{rewardLogs}}" wx:key="id">
        <text class="reward-remark">{{item.remark || item.type}}</text>
        <text class="reward-delta" wx:if="{{item.points > 0}}">+{{item.points}}积分</text>
      </view>
    </view>

    <view class="stats-row">
      <view class="stat-item">
        <image class="stat-icon-img" src="/images/my-icon-medal.png" mode="aspectFit"></image>
        <text class="stat-value" wx:if="{{isLoggedIn}}">{{userInfo.medals}}</text>
        <text class="stat-label">勋章</text>
      </view>
      <view class="stat-item">
        <image class="stat-icon-img" src="/images/my-icon-point.png" mode="aspectFit"></image>
        <text class="stat-value" wx:if="{{isLoggedIn}}">{{userInfo.points}}</text>
        <text class="stat-label">积分</text>
      </view>
      <view class="stat-item">
        <image class="stat-icon-img" src="/images/my-icon-fish.png" mode="aspectFit"></image>
        <text class="stat-value" wx:if="{{isLoggedIn}}">{{userInfo.fishFood}}</text>
        <text class="stat-label">鱼粮</text>
      </view>
    </view>
  </view>

  <!-- 菜单 -->
  <view class="menu-card">
    <view
      wx:for="{{menuList}}"
      wx:key="id"
      class="menu-item"
      data-id="{{item.id}}"
      bindtap="onMenuTap"
    >
      <text class="menu-text">{{item.title}}</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-wrap" wx:if="{{isLoggedIn}}">
    <view class="logout-btn" bindtap="onLogout">退出登录</view>
  </view>

  <view class="page-bottom-spacer"></view>
</view>
