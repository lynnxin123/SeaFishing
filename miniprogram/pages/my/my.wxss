page {
  background: #f5f5f5;
  height: 100%;
}

.my-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.nav-bar {
  background: #ffffff;
  padding-top: env(safe-area-inset-top);
  height: calc(88rpx + env(safe-area-inset-top));
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
  line-height: 88rpx;
}

/* 顶部浅灰整块：头像区 + 勋章/积分/鱼粮 */
.top-panel {
  background: #f5f7f9;
}

.user-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 40rpx 28rpx 28rpx 32rpx;
  background: transparent;
}

.login-hit {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: row;
  align-items: center;
}

.login-hit-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  width: 100%;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #e4e7ec;
}

.avatar-guest-img {
  background: #e4e7ec;
}

.login-tip {
  flex: 1;
  margin-left: 28rpx;
  font-size: 40rpx;
  font-weight: 600;
  color: #1a1a1a;
  line-height: 56rpx;
  white-space: nowrap;
}

.user-meta {
  flex: 1;
  margin-left: 24rpx;
  min-width: 0;
}

.name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #333333;
  max-width: 280rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-verify {
  font-size: 22rpx;
  color: #ff4d4f;
  border: 1rpx solid #ff4d4f;
  border-radius: 6rpx;
  padding: 2rpx 10rpx;
  line-height: 30rpx;
}

.level-tag {
  display: inline-flex;
  align-items: center;
  margin-top: 12rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, #f5e6c8, #e8c878);
}

.level-crown {
  font-size: 22rpx;
  color: #8b6914;
  margin-right: 6rpx;
}

.level-text {
  font-size: 24rpx;
  color: #6b4f10;
  font-weight: 600;
}

.bell-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* 消息铃铛：线框造型 */
.ui-bell {
  width: 48rpx;
  height: 54rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ui-bell__handle {
  width: 16rpx;
  height: 9rpx;
  border: 3rpx solid #727b8a;
  border-bottom: 0;
  border-radius: 12rpx 12rpx 0 0;
  box-sizing: border-box;
}

.ui-bell__dome {
  width: 42rpx;
  height: 30rpx;
  margin-top: -1rpx;
  border: 3rpx solid #727b8a;
  border-radius: 50% 50% 10rpx 10rpx;
  box-sizing: border-box;
}

.ui-bell__rim {
  width: 46rpx;
  height: 4rpx;
  margin-top: -3rpx;
  background: #727b8a;
  border-radius: 2rpx;
}

.ui-bell__clapper {
  width: 12rpx;
  height: 7rpx;
  margin-top: 5rpx;
  border: 3rpx solid #727b8a;
  border-top: 0;
  border-radius: 0 0 12rpx 12rpx;
  box-sizing: border-box;
}

.stats-row {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  justify-content: space-around;
  background: transparent;
  padding: 8rpx 24rpx 44rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
}

.stat-icon-img {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
  display: block;
}

.stat-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #333333;
  line-height: 40rpx;
  margin-bottom: 4rpx;
}

.stat-label {
  font-size: 26rpx;
  color: #b0b8c4;
  line-height: 36rpx;
}

/* 菜单 */
.menu-card {
  margin: 0;
  background: #ffffff;
  border-radius: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 28rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-text {
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 36rpx;
  color: #cccccc;
  line-height: 1;
}

/* 退出登录 */
.logout-wrap {
  margin: 48rpx 24rpx 0;
}

.logout-btn {
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: #000000;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 8rpx;
}

.page-bottom-spacer {
  height: 32rpx;
}
