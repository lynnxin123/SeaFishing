.page-shell { min-height: 100vh; padding: 30rpx 24rpx 160rpx; background: #e6f5ff; }
.page-title { font-size: 36rpx; font-weight: 700; color: #0b4f8c; margin-bottom: 24rpx; }
.user-card { display: flex; align-items: center; padding: 20rpx; border-radius: 28rpx; background: #eef7ff; margin-bottom: 18rpx; }
.user-avatar { width: 90rpx; height: 90rpx; border-radius: 50%; margin-right: 18rpx; }
.user-name { font-size: 28rpx; color: #0c5f91; font-weight: 700; margin-bottom: 8rpx; }
.user-sub { font-size: 24rpx; color: #6f8aa8; }
.section-card { background: #ffffff; border-radius: 28rpx; padding: 28rpx; box-shadow: 0 14rpx 32rpx rgba(0,0,0,0.10); }
.section-title { font-size: 30rpx; color: #0c5daf; font-weight: 700; margin-bottom: 18rpx; }
.section-text { font-size: 24rpx; color: #5e7b9a; line-height: 36rpx; margin-bottom: 24rpx; }
.auth-button { width: 100%; background: #0c6dff; color: #ffffff; border-radius: 28rpx; height: 80rpx; font-size: 28rpx; }
.event-list { margin-top: 14rpx; }
.event-item { display: flex; justify-content: space-between; align-items: center; padding: 18rpx 22rpx; background: #f6fbff; border-radius: 24rpx; margin-bottom: 14rpx; }
.event-item-title { font-size: 24rpx; color: #0c5f91; width: 64%; }
.event-item-meta { font-size: 22rpx; color: #7a8ea7; text-align: right; }
