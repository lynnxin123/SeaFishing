.feature-page {
  min-height: 100vh;
  background: #f5f9fc;
}

.feature-body {
  padding: 80rpx 48rpx;
}

.feature-placeholder {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 64rpx 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 32rpx rgba(11, 79, 140, 0.08);
}

.feature-placeholder__icon {
  display: block;
  font-size: 72rpx;
}

.feature-placeholder__title {
  display: block;
  margin-top: 24rpx;
  font-size: 36rpx;
  font-weight: 700;
  color: #141d3a;
}

.feature-placeholder__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #98a4b8;
}
