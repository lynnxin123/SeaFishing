.agreement-page {
  min-height: 100vh;
  background: #f5f6f8;
  display: flex;
  flex-direction: column;
}

.agreement-scroll {
  flex: 1;
  height: 0;
}

.agreement-content {
  padding: 24rpx 32rpx 48rpx;
}

.agreement-body {
  font-size: 28rpx;
  color: #333333;
  line-height: 48rpx;
  white-space: pre-wrap;
}
