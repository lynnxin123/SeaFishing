.page-shell { min-height: 100vh; padding: 30rpx 24rpx 160rpx; background: #e6f5ff; }
.page-title { font-size: 36rpx; font-weight: 700; color: #0b4f8c; margin-bottom: 24rpx; }
.section-card { background: #ffffff; border-radius: 28rpx; padding: 28rpx; box-shadow: 0 14rpx 32rpx rgba(0,0,0,0.10); margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; color: #0c5daf; font-weight: 700; margin-bottom: 18rpx; }
.section-text { font-size: 24rpx; color: #5e7b9a; line-height: 36rpx; margin-bottom: 12rpx; }
.event-row { background: #ffffff; border-radius: 24rpx; padding: 22rpx; margin-bottom: 14rpx; box-shadow: 0 12rpx 28rpx rgba(0,0,0,0.09); }
.event-row-title { font-size: 26rpx; color: #0c6dff; margin-bottom: 8rpx; }
.event-row-meta { font-size: 22rpx; color: #7a8ea7; }
