.event-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f4fc 0%, #f5f9fc 28%, #ffffff 55%);
  padding-bottom: calc(140rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.login-strip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 0 24rpx 8rpx;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border-radius: 16rpx;
  border: 1rpx solid #dce9f5;
  box-shadow: 0 6rpx 18rpx rgba(11, 79, 140, 0.06);
}

.login-strip__text {
  font-size: 24rpx;
  color: #5e7b9a;
}

.login-strip__btn {
  padding: 10rpx 24rpx;
  background: linear-gradient(135deg, #0c6dff, #0b4f8c);
  color: #ffffff;
  font-size: 24rpx;
  border-radius: 28rpx;
  font-weight: 600;
}

.welcome-strip {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin: 0 24rpx 8rpx;
  padding: 14rpx 20rpx;
}

.welcome-strip__avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.welcome-strip__avatar--placeholder {
  background: #0b4f8c;
  color: #ffffff;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 56rpx;
  text-align: center;
}

.welcome-strip__text {
  font-size: 26rpx;
  color: #2b3a55;
  font-weight: 600;
}

.event-content {
  padding: 8rpx 24rpx 24rpx;
}

/* 广告招商 */
.ad-banner {
  position: relative;
  height: 200rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 28rpx rgba(11, 79, 140, 0.12);
}

.ad-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.ad-banner__mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, rgba(11, 79, 140, 0.75) 0%, rgba(11, 79, 140, 0.45) 55%, rgba(11, 79, 140, 0.25) 100%);
}

.ad-banner__body {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx;
}

.ad-banner__tag {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 2rpx;
}

.ad-banner__title {
  display: block;
  margin-top: 8rpx;
  font-size: 40rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 6rpx;
}

.ad-banner__phone {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.35);
}

.ad-banner__phone-icon {
  font-size: 32rpx;
}

.ad-banner__phone-num {
  margin-top: 6rpx;
  font-size: 26rpx;
  color: #ffffff;
  font-weight: 600;
}

/* 赛事报名横幅 */
.signup-banner {
  position: relative;
  margin-top: 20rpx;
  height: 160rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 14rpx 32rpx rgba(12, 109, 255, 0.25);
}

.signup-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.signup-banner__mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(12, 109, 255, 0.92) 0%, rgba(11, 79, 140, 0.88) 100%);
}

.signup-banner__text {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 36rpx;
}

.signup-banner__title {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 4rpx;
}

.signup-banner__sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 4rpx;
}

.signup-banner__deco {
  position: absolute;
  z-index: 1;
  pointer-events: none;
}

.signup-banner__deco--fish {
  right: 48rpx;
  top: 28rpx;
  font-size: 48rpx;
  opacity: 0.35;
}

.signup-banner__deco--line {
  right: 24rpx;
  bottom: 20rpx;
  width: 120rpx;
  height: 60rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  transform: rotate(-15deg);
}

/* 功能卡片网格 */
.feature-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 24rpx;
}

.feature-card {
  position: relative;
  width: calc(50% - 10rpx);
  box-sizing: border-box;
  border-radius: 24rpx;
  padding: 28rpx 24rpx 32rpx;
  min-height: 240rpx;
  overflow: visible;
}

.feature-card--blue {
  background: linear-gradient(160deg, #e8f4ff 0%, #f2f8ff 100%);
  border: 1rpx solid #d4e8fa;
}

.feature-card--cream {
  background: linear-gradient(160deg, #faf5ee 0%, #fff9f2 100%);
  border: 1rpx solid #f0e6d8;
}

.feature-card--lavender {
  background: linear-gradient(160deg, #f0f2fa 0%, #f8f9fd 100%);
  border: 1rpx solid #e2e6f2;
}

.feature-card__icon-wrap {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 8rpx 20rpx rgba(11, 79, 140, 0.12);
}

.feature-card__icon {
  width: 100%;
  height: 100%;
}

.feature-card__title {
  display: block;
  margin-top: 20rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #141d3a;
}

.feature-card__sub {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #98a4b8;
  line-height: 32rpx;
}

.service-btn {
  position: absolute;
  right: -8rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 88rpx;
  padding: 12rpx 0;
  background: linear-gradient(180deg, #0c6dff, #0b4f8c);
  border-radius: 44rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(12, 109, 255, 0.35);
  border: none;
  line-height: 1.2;
}

.service-btn::after {
  border: none;
}

.service-btn__icon {
  font-size: 28rpx;
  line-height: 1;
}

.service-btn__text {
  margin-top: 4rpx;
  font-size: 18rpx;
  color: #ffffff;
  writing-mode: vertical-rl;
  letter-spacing: 2rpx;
}

/* 举报 / 申诉 */
.utility-grid {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.utility-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 28rpx 24rpx;
  background: #ffffff;
  border-radius: 20rpx;
  border: 1rpx solid #eef2f7;
  box-shadow: 0 8rpx 22rpx rgba(11, 79, 140, 0.06);
}

.utility-card__icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  flex-shrink: 0;
  position: relative;
}

.utility-card__icon--gavel {
  background: #f0f7ff;
  border: 2rpx solid #0b4f8c;
}

.utility-card__icon--gavel::before {
  content: '';
  position: absolute;
  left: 14rpx;
  top: 16rpx;
  width: 28rpx;
  height: 8rpx;
  background: #0b4f8c;
  border-radius: 4rpx;
  transform: rotate(-25deg);
}

.utility-card__icon--gavel::after {
  content: '';
  position: absolute;
  right: 12rpx;
  bottom: 14rpx;
  width: 20rpx;
  height: 20rpx;
  border: 3rpx solid #0b4f8c;
  border-radius: 4rpx;
}

.utility-card__icon--doc {
  background: #f0f7ff;
  border: 2rpx solid #0b4f8c;
}

.utility-card__icon--doc::before {
  content: '';
  position: absolute;
  left: 16rpx;
  top: 12rpx;
  width: 24rpx;
  height: 32rpx;
  border: 2rpx solid #0b4f8c;
  border-radius: 4rpx;
}

.utility-card__icon--doc::after {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 20rpx;
  width: 16rpx;
  height: 2rpx;
  background: #0b4f8c;
  box-shadow: 0 6rpx 0 #0b4f8c, 0 12rpx 0 #0b4f8c;
}

.utility-card__title {
  font-size: 28rpx;
  font-weight: 600;
  color: #141d3a;
}

/* 登录弹窗 */
.login-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 300;
}

.login-modal {
  position: fixed;
  left: 48rpx;
  right: 48rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: 301;
  background: #ffffff;
  border-radius: 28rpx;
  padding: 36rpx 32rpx 32rpx;
  box-shadow: 0 20rpx 48rpx rgba(0, 0, 0, 0.15);
}

.login-modal__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.login-modal__title {
  font-size: 32rpx;
  font-weight: 700;
  color: #141d3a;
}

.login-modal__close {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  color: #98a4b8;
  font-size: 28rpx;
}

.login-modal__desc {
  display: block;
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #5e7b9a;
  line-height: 40rpx;
}

.login-modal__agree {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  margin-top: 28rpx;
  font-size: 22rpx;
}

.agree-check {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #c7d0dd;
  border-radius: 8rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.agree-check--on {
  background: #0b4f8c;
  border-color: #0b4f8c;
}

.agree-tick {
  width: 14rpx;
  height: 8rpx;
  border-left: 3rpx solid #ffffff;
  border-bottom: 3rpx solid #ffffff;
  transform: rotate(-45deg) translateY(-2rpx);
}

.login-modal__agree-text {
  color: #5e7b9a;
}

.login-modal__link {
  color: #0c6dff;
}

.login-modal__btn-wrap {
  margin-top: 28rpx;
}

.login-modal__btn {
  width: 100%;
  height: 88rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  line-height: 1;
  text-align: center;
  background: linear-gradient(135deg, #0c6dff, #0b4f8c);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  box-sizing: border-box;
}

.login-modal__btn::after {
  border: none;
}
